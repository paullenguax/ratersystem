rules_version = '2';


service cloud.firestore {
  match /databases/{database}/documents {

    // ── helpers ──────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/people/$(request.auth.uid)).data.role == 'admin';
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ── people ────────────────────────────────────────────────────────────────
    // Admins can read/write all. Authenticated users can read their own record.

    match /people/{personId} {
      allow read: if isAdmin() || isSelf(personId);
      allow write: if isAdmin();
    }

    // ── config ────────────────────────────────────────────────────────────────
    // Admin read/write only. Contains Canvas API token — do not expose to non-admins.

    match /config/{docId} {
      allow read, write: if isAdmin();
    }

    // ── sessions ──────────────────────────────────────────────────────────────

    match /sessions/{sessionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── assignments ───────────────────────────────────────────────────────────
    // Raters can read their own assignments and update status/notes.
    // Admins can read/write all.

    match /assignments/{assignmentId} {
      allow read: if isAdmin() ||
        (isSignedIn() && resource.data.raterId == request.auth.uid);
      allow create, delete: if isAdmin();
      allow update: if isAdmin() ||
        (isSignedIn() && resource.data.raterId == request.auth.uid);
    }

    // ── scores ────────────────────────────────────────────────────────────────

    match /scores/{scoreId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() ||
        (isSignedIn() && resource.data.raterId == request.auth.uid);
    }

    // ── test_bank ─────────────────────────────────────────────────────────────

    match /test_bank/{testId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── certificates ─────────────────────────────────────────────────────────
    // Public read so /validate/:certNumber works without auth.

    match /certificates/{certId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── cert_config ───────────────────────────────────────────────────────────
    // Public read so ValidatePage can resolve template URLs without auth.

    match /cert_config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── official_forms ────────────────────────────────────────────────────────

    match /official_forms/{formId} {
      allow read, write: if isAdmin();
    }

    // ── rasch_runs ────────────────────────────────────────────────────────────

    match /rasch_runs/{runId} {
      allow read, write: if isAdmin();
    }

    // ── benchmark_items ───────────────────────────────────────────────────────
    // Public read — Benchmark Check app reads items without auth.

    match /benchmark_items/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── benchmark_results ─────────────────────────────────────────────────────
    // Public write — Benchmark Check app submits results without auth.

    match /benchmark_results/{resultId} {
      allow read: if isAdmin();
      allow write: if true;
    }

    // ── practice_sessions ─────────────────────────────────────────────────────
    // Public read so the public scoring page can look up a session by code.
    // Only admins can create/update/delete sessions.

    match /practice_sessions/{sessionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── practice_scores ───────────────────────────────────────────────────────
    // Public write — participants submit without auth.
    // Admin read only — trainer sees results.

    match /practice_scores/{scoreId} {
      allow read: if isAdmin();
      allow write: if true;
    }

    // ── canvasEnrollmentLog ───────────────────────────────────────────────────
    // Written only by Firebase Functions (admin SDK bypasses rules).
    // Readable by admins only.

    match /canvasEnrollmentLog/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

  }
}
